# ─── Supabase ─────────────────────────────────────────────────────────────────
# Web: accesible desde el browser (prefijo NEXT_PUBLIC_ = expuesto en bundle)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: NUNCA exponer en el browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# ─── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-key
EMAIL_FROM=noreply@allmotors.cl

# ─── TallerGP (Migration Toolkit + enriquecimiento de vehículo) ───────────────
# SERVER-ONLY (sin NEXT_PUBLIC): nunca se exponen al browser.
TALLERGP_API_URL=https://api.tallergp.com
TALLERGP_API_KEY=your-tallergp-api-key
# Bearer JWT obtenido via OAuth2 client_credentials o token fijo del portal.
# El enriquecimiento de vehículo por patente requiere TALLERGP_API_URL + TALLERGP_BEARER_TOKEN.
TALLERGP_BEARER_TOKEN=

# ─── Enriquecimiento de vehículo por patente (proveedores externos) ───────────
# SERVER-ONLY. Proveedor PRIMARIO recomendado: GetAPI.cl (API REST por patente).
#   GET https://chile.getapi.cl/v1/vehicles/plate/{patente}  ·  header X-Api-Key
GETAPI_API_KEY=
# Base opcional (por defecto https://chile.getapi.cl/v1)
GETAPI_VEHICLES_URL=

# Selección del proveedor de enriquecimiento (server-only). Cadena por prioridad:
#   getapi (primario) → tallergp (secundario). Override:
#   getapi   → fuerza GetAPI.cl (requiere GETAPI_API_KEY)
#   tallergp → fuerza TallerGP (requiere TALLERGP_API_URL + TALLERGP_BEARER_TOKEN)
#   mock     → datos ficticios para probar sin proveedor real
#   (vacío)/auto → usa todos los configurados, por prioridad; si ninguno, ingreso manual
VEHICLE_ENRICHMENT_PROVIDER=

# ─── Mobile (Expo — copiar a apps/mechanic/.env) ──────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EAS_PROJECT_ID=your-eas-project-id

# ─── IA (V1+) ─────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-your-key   # Solo server, para RAG y diagnóstico asistido
