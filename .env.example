# ─── Supabase ─────────────────────────────────────────────────────────────────
# Web: accesible desde el browser (prefijo NEXT_PUBLIC_ = expuesto en bundle)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: NUNCA exponer en el browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# ─── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-key
EMAIL_FROM=noreply@allmotors.cl

# ─── TallerGP (Migration Toolkit) ─────────────────────────────────────────────
TALLERGP_API_URL=https://api.tallergp.com
TALLERGP_API_KEY=your-tallergp-api-key
# Bearer JWT obtenido via OAuth2 client_credentials o token fijo del portal
TALLERGP_BEARER_TOKEN=

# ─── Mobile (Expo — copiar a apps/mechanic/.env) ──────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EAS_PROJECT_ID=your-eas-project-id

# ─── IA (V1+) ─────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-your-key   # Solo server, para RAG y diagnóstico asistido
