{
  "name": "all-motors-cloud",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@allmotors/web",
    "dev:mobile": "turbo run dev --filter=@allmotors/mechanic",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@allmotors/web",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "setup": "pnpm install && cp -n .env.example .env.local || true",
    "db:types": "supabase gen types typescript --local > packages/database/src/generated/types.ts",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "turbo": "^2.0.0",
    "typescript": "^5.6.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "migration-toolkit"
  ]
}
