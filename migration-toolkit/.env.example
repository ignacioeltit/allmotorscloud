# ─────────────────────────────────────────────────────────────
# TallerGP API — Credenciales de solo lectura
# Copiar este archivo como .env y completar los valores reales
# NUNCA commitear .env
# ─────────────────────────────────────────────────────────────

# URL base de la API (no cambiar salvo indicación de TallerGP)
TALLERGP_API_URL=https://api.tallergp.com

# Opción A: OAuth2 — client_id + client_secret (flujo client_credentials)
# Se obtienen desde: Cuenta TallerGP → Configuración → API → Acceso general
TALLERGP_CLIENT_ID=
TALLERGP_CLIENT_SECRET=
TALLERGP_TOKEN_URL=https://api.tallergp.com/oauth/token

# Opción B: Token directo (si TallerGP entrega un Bearer token fijo)
# Si se define, se usa directamente sin hacer el flujo OAuth
TALLERGP_ACCESS_TOKEN=

# ─────────────────────────────────────────────────────────────
# Comportamiento del toolkit
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Requests por segundo máximo a la API (no subir de 5 sin autorización)
RATE_LIMIT_RPS=3
MAX_RETRIES=3
# Directorio base donde se guardan los exports
EXPORT_DIR=./exports
