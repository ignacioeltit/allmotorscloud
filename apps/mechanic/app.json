{
  "expo": {
    "name": "All Motors Mecánico",
    "slug": "allmotors-mechanic",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "allmotors-mechanic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "cl.allmotors.mechanic"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1d4ed8"
      },
      "package": "cl.allmotors.mechanic"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-secure-store",
      [
        "expo-sqlite",
        {
          "useSQLiteCApi": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "REEMPLAZAR_CON_EAS_PROJECT_ID"
      }
    }
  }
}
